{
  "name": "finpulse",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev:admin": "pnpm --filter finpulse-admin dev",
    "dev:portal": "pnpm --filter finpulse-portal dev",
    "dev:mobile": "pnpm --filter finpulse-mobile start",
    "dev:mobile:ios": "pnpm --filter finpulse-mobile ios",
    "dev:mobile:android": "pnpm --filter finpulse-mobile android",
    "dev:server": "bash scripts/backend/start-backend.sh",
    "build": "turbo run build",
    "check-types": "pnpm -r run --if-present check-types",
    "tsc": "pnpm -r run --if-present check-types",
    "start": "pnpm --filter finpulse-admin start",
    "test": "pnpm run test:api",
    "test:all": "pnpm -r --parallel run test",
    "test:all:coverage": "pnpm -r --parallel run test:coverage",
    "test:type": "pnpm -r --parallel run type-check",
    "test:api": "cd apps/server-python && .venv/bin/python -m pytest tests -v",
    "test:api:go": "cd apps/server-go && go test ./cmd/server -v -count=1",
    "lint": "pnpm --filter finpulse-admin lint",
    "pre-commit": "pnpm check-types && pnpm test:all && pnpm lint-staged",
    "stop:backend": "bash scripts/backend/stop-backend.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "vitest related --run"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.6.0",
    "turbo": "^2.5.4",
    "typescript": "^5"
  }
}
