EXPO_PUBLIC_API_BASE_URL=http://localhost:8801
# Analytics and API use this; /api/v1 is appended if missing.

# Optional: pre-fill login (dev/demo only)
# EXPO_PUBLIC_DEMO_EMAIL=demo@example.com
# EXPO_PUBLIC_DEMO_PASSWORD=demo123

# Optional: Ethereum chain (defaults to Sepolia testnet if unset)
# EXPO_PUBLIC_ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# EXPO_PUBLIC_ETH_CHAIN_ID=11155111
# EXPO_PUBLIC_ETH_CHAIN_NAME=Sepolia
# For mainnet: set chain ID 1, mainnet RPC URL, and chainName="Ethereum Mainnet"