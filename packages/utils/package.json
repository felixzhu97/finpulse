{
  "name": "@fintech/utils",
  "version": "0.1.0",
  "private": true,
  "description": "Shared utility functions for FinPulse",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "check-types": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.0.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
